<Window x:Class="ExcelFilterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтр Excel (-K, -S)" Height="260" Width="480">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="42.96"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Обработка Excel файла"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   TextAlignment="Center"/>

        <!-- Инструкция -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,10">
        <Run Text="1. Нажмите кнопку ниже и выберите Excel-файл."/><LineBreak/>
        <Run Text="2. Программа возьмет первый лист файла."/><LineBreak/>
        <Run Text="3. Верхняя строка будет заголовком на листах '-K' и '-S'."/><LineBreak/>
        <Run Text="4. Строки с '-K' переносим на лист '-K'."/><LineBreak/>
        <Run Text="5. Строки с '-S' переносим на лист '-S'."/><LineBreak/>
        <Run Text="5. Новокузнецк 2026-14-07 АСКО."/><LineBreak/>
        </TextBlock>

        <!-- Кнопка запуска -->
        <Button Grid.Row="2"
                Content="Выбрать файл и выполнить обработку"
                HorizontalAlignment="Center"
                Padding="10"
                Click="ProcessExcel_Click"
                ToolTip="Нажмите, чтобы выбрать Excel-файл и запустить фильтрацию по -K и -S" Margin="0,5,0,0" Width="234"/>
    </Grid>
</Window>